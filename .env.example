# Airflow SPCS Deployment Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Note: Inside SPCS, Snowflake credentials are NOT needed —
# DAGs use SPCS native OAuth tokens automatically (zero-config).
# These variables are only needed for LOCAL development with docker compose.

# ─── Snowflake Connection (local dev only) ───
# Required for DAGs that connect to Snowflake (example_snowflake, snowflake_etl_pipeline).
# The example_taskflow DAG works without these.
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=
SNOWFLAKE_PASSWORD=

# Optional overrides (defaults match the SPCS deployment)
SNOWFLAKE_DATABASE=AIRFLOW_DB
SNOWFLAKE_SCHEMA=AIRFLOW_SCHEMA
SNOWFLAKE_WAREHOUSE=AIRFLOW_SETUP_WH
SNOWFLAKE_ROLE=
