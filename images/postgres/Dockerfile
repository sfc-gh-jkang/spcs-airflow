FROM postgres:17.9

# PostgreSQL 17.9 - Latest version supported by Airflow 3.1.7
# Airflow supports PostgreSQL 13, 14, 15, 16, 17 only.
# PostgreSQL 18 is NOT supported. See docs/PG18_INCOMPATIBILITY.md

# Use default postgres configuration.
# Custom pg_hba.conf and postgresql.conf can be mounted via SPCS volumes if needed.

EXPOSE 5432
